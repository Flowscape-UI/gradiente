{
  "name": "gradiente",
  "type": "module",
  "version": "2.0.0",
  "description": "Lightweight gradient toolkit for modern rendering systems.",
  "author": "Nice Arti <nikcrav@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/Flowscape-UI/gradiente#readme",
  "keywords": [
    "gradiente",
    "gradient",
    "gradients",
    "flowscape",
    "color"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Flowscape-UI/gradiente.git"
  },
  "bugs": {
    "url": "https://github.com/Flowscape-UI/gradiente/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@codemirror/basic-setup": "^0.20.0",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.41.1",
    "@eslint/js": "^10.0.1",
    "@types/culori": "^4.0.1",
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260418.1",
    "@vue-flow/background": "^1.3.2",
    "@vue-flow/core": "^1.48.2",
    "bumpp": "^11.0.1",
    "eslint": "^10.2.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.8",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "culori": "^4.0.2"
  }
}
